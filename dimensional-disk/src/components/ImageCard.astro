---
import { Image } from 'astro:assets';
interface ImageCardProps {
  src: string;
  alt: string;
  title?: string;
  description?: string;
}
---
<div class="rounded overflow-hidden shadow-lg bg-white dark:bg-gray-800">
  <Image src={props.src} alt={props.alt} class="w-full h-48 object-cover" loading="lazy" />
  {props.title && <h3 class="text-xl font-bold p-4 pt-2">{props.title}</h3>}
  {props.description && <p class="p-4 pt-0 text-gray-700 dark:text-gray-300">{props.description}</p>}
</div>
