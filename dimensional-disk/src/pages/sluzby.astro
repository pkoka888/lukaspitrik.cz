---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

const services = [
  {
    id: 'zamereni',
    title: 'Zaměření stavby + cenová nabídka',
    description: 'Zaměříme vaši stavbu a zdarma vytvoříme nezávaznou cenovou nabídku.',
    icon: `<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 13l6-3m-6 3V7m6 10l4.553 2.276A1 1 0 0021 18.382V7.618a1 1 0 00-.553-.894L15 4m0 13V4m0 0L9 7" /></svg>`,
    price: 'Zdarma'
  },
  {
    id: 'nabidka',
    title: 'Cenová nabídka',
    description: 'Na základě vámi zaslaných podkladů zhotovíme zdarma nezávaznou cenovou nabídku.',
    icon: `<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" /></svg>`,
    price: 'Zdarma'
  },
  {
    id: 'kuchyně',
    title: 'Zaměření kuchyně',
    description: 'Zamluvte si termín na zaměření kuchyňské linky. Zaměření včetně návrhu a kalkulace je zdarma.',
    icon: `<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" /></svg>`,
    price: 'Zdarma'
  }
];

const mainServices = [
  {
    title: 'Sádrokartonářské práce',
    items: ['podhledy', 'stěny, předstěny', 'kastlíky', 'půdní vestavby'],
    description: 'Skladba dle technologických postupů s kvalitními materiály.'
  },
  {
    title: 'Obkladačské práce',
    items: ['malé i velké formáty', 'sprchové kouty na míru', 'jolly edge', 'řezání na vodní pile'],
    description: 'Koupelny pro naše zákazníky realizujeme na klíč.'
  },
  {
    title: 'Betonářské práce',
    items: ['základové desky', 'podkladní betony', 'pohledové betony', 'opěrné zdi', 'betonové ploty a zídky'],
    description: 'Kvalitní betonářské práce s profesionálním přístupem.'
  },
  {
    title: 'Stavební práce',
    items: ['úpravy povrchů vnitřní', 'úpravy povrchů vnější', 'podlahy', 'kompletní rekonstrukce', 'výstavba'],
    description: 'Rádi za Vás převezmeme starosti s rekonstrukcí nebo výstavbou.'
  }
];
---

<BaseLayout 
  title="Služby | STAVEBNÍ PRÁCE Lukáš Pitřík" 
  description="Naše služby - sádrokarton, obklady, beton, kuchyně na míru. Kompletní stavební práce v Teplicích a okolí."
>
  <Nav />
  <main class="pt-16">
    <!-- Hero -->
    <section class="py-20 bg-gradient-to-br from-slate-900 to-slate-800">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
        <span class="inline-block px-4 py-1 bg-orange-500/20 text-orange-400 text-sm font-medium rounded-full mb-4">SLUŽBY</span>
        <h1 class="text-4xl md:text-5xl font-bold text-white mb-6">Co vše nabízíme</h1>
        <p class="text-xl text-slate-300 max-w-2xl mx-auto">
          Komplexní stavební práce pro váš dům či byt. Od návrhu po realizaci.
        </p>
      </div>
    </section>

    <!-- Quick Order Services -->
    <section class="py-16 bg-orange-500">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="grid md:grid-cols-3 gap-6">
          {services.map(service => (
            <div class="bg-white rounded-xl p-6 text-center hover:shadow-xl transition-shadow">
              <div class="w-16 h-16 bg-orange-100 rounded-2xl flex items-center justify-center mx-auto mb-4 text-orange-500" set:html={service.icon} />
              <h3 class="text-lg font-bold text-slate-800 mb-2">{service.title}</h3>
              <p class="text-slate-600 text-sm mb-4">{service.description}</p>
              <span class="inline-block px-3 py-1 bg-green-100 text-green-700 text-xs font-medium rounded-full">{service.price}</span>
              <a href="/kontakty" class="block mt-4 w-full py-2 bg-orange-500 text-white font-medium rounded-lg hover:bg-orange-600 transition-colors">
                Objednat
              </a>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Main Services -->
    <section class="py-20 bg-white dark:bg-slate-900">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-16">
          <h2 class="text-3xl md:text-4xl font-bold text-slate-800 dark:text-white mb-4">Hlavní služby</h2>
        </div>
        <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-6">
          {mainServices.map(service => (
            <div class="bg-slate-50 dark:bg-slate-800 rounded-2xl p-6 hover:shadow-xl hover:shadow-orange-500/10 transition-all">
              <h3 class="text-lg font-bold text-slate-800 dark:text-white mb-3">{service.title}</h3>
              <ul class="space-y-2 mb-4">
                {service.items.map(item => (
                  <li class="flex items-center gap-2 text-sm text-slate-600 dark:text-slate-400">
                    <svg class="w-4 h-4 text-orange-500 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                    </svg>
                    <span>{item}</span>
                  </li>
                ))}
              </ul>
              <p class="text-sm text-slate-500 dark:text-slate-500">{service.description}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- CTA -->
    <section class="py-20 bg-gradient-to-r from-slate-900 to-slate-800">
      <div class="max-w-4xl mx-auto px-4 text-center">
        <h2 class="text-3xl md:text-4xl font-bold text-white mb-6">Potřebujete poradit?</h2>
        <p class="text-xl text-slate-300 mb-8">
          Neváhejte nás kontaktovat. Rádi vám pomůžeme s výběrem správného řešení.
        </p>
        <a href="/kontakty" class="inline-flex items-center gap-2 px-8 py-4 bg-orange-500 hover:bg-orange-600 text-white font-semibold rounded-lg transition-colors">
          <span>Kontaktovat</span>
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
          </svg>
        </a>
      </div>
    </section>
  </main>
  <Footer />
</BaseLayout>
