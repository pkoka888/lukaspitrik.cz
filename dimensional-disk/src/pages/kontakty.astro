---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

const companyInfo = {
  name: 'STAVEBNÍ PRÁCE Lukáš Pitřík',
  phone: '775 336 651',
  email: 'pitrik.lukas90@gmail.com',
  ico: '03420698',
  address: 'Teplice, Severní Čechy'
};
---

<BaseLayout 
  title="Kontakty | STAVEBNÍ PRÁCE Lukáš Pitřík" 
  description="Kontaktujte nás - stavební práce, rekonstrukce, kuchyně na míru v Teplicích. Telefon 775 336 651, email pitrik.lukas90@gmail.com"
>
  <Nav />
  <main class="pt-16">
    <!-- Hero -->
    <section class="py-20 bg-gradient-to-br from-slate-900 to-slate-800">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
        <span class="inline-block px-4 py-1 bg-orange-500/20 text-orange-400 text-sm font-medium rounded-full mb-4">KONTAKTY</span>
        <h1 class="text-4xl md:text-5xl font-bold text-white mb-6">Spojte se s námi</h1>
        <p class="text-xl text-slate-300 max-w-2xl mx-auto">
          Rádi vám poradíme s vaším projektem. Neváhejte nás kontaktovat.
        </p>
      </div>
    </section>

    <!-- Contact Info -->
    <section class="py-20 bg-white dark:bg-slate-900">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="grid lg:grid-cols-2 gap-12">
          <!-- Info Cards -->
          <div>
            <div class="grid sm:grid-cols-2 gap-4">
              <a href={`tel:${companyInfo.phone}`} class="flex items-center gap-4 p-6 bg-slate-50 dark:bg-slate-800 rounded-2xl hover:shadow-lg hover:shadow-orange-500/10 transition-all">
                <div class="w-14 h-14 bg-orange-100 dark:bg-orange-900/30 rounded-xl flex items-center justify-center text-orange-500">
                  <svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
                  </svg>
                </div>
                <div>
                  <p class="text-sm text-slate-500 dark:text-slate-400">Telefon</p>
                  <p class="text-lg font-bold text-slate-800 dark:text-white">{companyInfo.phone}</p>
                </div>
              </a>

              <a href={`mailto:${companyInfo.email}`} class="flex items-center gap-4 p-6 bg-slate-50 dark:bg-slate-800 rounded-2xl hover:shadow-lg hover:shadow-orange-500/10 transition-all">
                <div class="w-14 h-14 bg-orange-100 dark:bg-orange-900/30 rounded-xl flex items-center justify-center text-orange-500">
                  <svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                  </svg>
                </div>
                <div>
                  <p class="text-sm text-slate-500 dark:text-slate-400">Email</p>
                  <p class="text-lg font-bold text-slate-800 dark:text-white">{companyInfo.email}</p>
                </div>
              </a>

              <div class="flex items-center gap-4 p-6 bg-slate-50 dark:bg-slate-800 rounded-2xl">
                <div class="w-14 h-14 bg-orange-100 dark:bg-orange-900/30 rounded-xl flex items-center justify-center text-orange-500">
                  <svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                  </svg>
                </div>
                <div>
                  <p class="text-sm text-slate-500 dark:text-slate-400">Adresa</p>
                  <p class="text-lg font-bold text-slate-800 dark:text-white">{companyInfo.address}</p>
                </div>
              </div>

              <div class="flex items-center gap-4 p-6 bg-slate-50 dark:bg-slate-800 rounded-2xl">
                <div class="w-14 h-14 bg-orange-100 dark:bg-orange-900/30 rounded-xl flex items-center justify-center text-orange-500">
                  <svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
                  </svg>
                </div>
                <div>
                  <p class="text-sm text-slate-500 dark:text-slate-400">IČO</p>
                  <p class="text-lg font-bold text-slate-800 dark:text-white">{companyInfo.ico}</p>
                </div>
              </div>
            </div>

            <!-- Social Links -->
            <div class="flex gap-4 mt-8">
              <a href="https://instagram.com/lukys90/" target="_blank" rel="noopener noreferrer" class="flex items-center gap-2 px-6 py-3 bg-slate-100 dark:bg-slate-800 rounded-xl text-slate-600 dark:text-slate-400 hover:bg-orange-500 hover:text-white transition-colors">
                <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/>
                </svg>
                <span>Instagram</span>
              </a>
              <a href="https://facebook.com/profile.php?id=61552250341023" target="_blank" rel="noopener noreferrer" class="flex items-center gap-2 px-6 py-3 bg-slate-100 dark:bg-slate-800 rounded-xl text-slate-600 dark:text-slate-400 hover:bg-orange-500 hover:text-white transition-colors">
                <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.955 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
                </svg>
                <span>Facebook</span>
              </a>
              <a href={`https://wa.me/420775336651`} target="_blank" rel="noopener noreferrer" class="flex items-center gap-2 px-6 py-3 bg-green-500 text-white rounded-xl hover:bg-green-600 transition-colors">
                <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
                </svg>
                <span>WhatsApp</span>
              </a>
            </div>
          </div>

          <!-- Contact Form -->
          <div class="bg-slate-50 dark:bg-slate-800 rounded-2xl p-8">
            <h3 class="text-xl font-bold text-slate-800 dark:text-white mb-6">Nezávazná poptávka</h3>
            <form class="space-y-4" id="contact-form">
              <div class="grid sm:grid-cols-2 gap-4">
                <div>
                  <label for="name" class="block text-sm font-medium text-slate-700 dark:text-slate-300 mb-1">Jméno *</label>
                  <input type="text" id="name" name="name" required class="w-full px-4 py-3 bg-white dark:bg-slate-700 border border-slate-200 dark:border-slate-600 rounded-lg focus:ring-2 focus:ring-orange-500 focus:border-orange-500 text-slate-800 dark:text-white" placeholder="Vaše jméno" />
                </div>
                <div>
                  <label for="phone" class="block text-sm font-medium text-slate-700 dark:text-slate-300 mb-1">Telefon</label>
                  <input type="tel" id="phone" name="phone" class="w-full px-4 py-3 bg-white dark:bg-slate-700 border border-slate-200 dark:border-slate-600 rounded-lg focus:ring-2 focus:ring-orange-500 focus:border-orange-500 text-slate-800 dark:text-white" placeholder="775 336 651" />
                </div>
              </div>
              <div>
                <label for="email" class="block text-sm font-medium text-slate-700 dark:text-slate-300 mb-1">Email *</label>
                <input type="email" id="email" name="email" required class="w-full px-4 py-3 bg-white dark:bg-slate-700 border border-slate-200 dark:border-slate-600 rounded-lg focus:ring-2 focus:ring-orange-500 focus:border-orange-500 text-slate-800 dark:text-white" placeholder="email@email.cz" />
              </div>
              <div>
                <label for="service" class="block text-sm font-medium text-slate-700 dark:text-slate-300 mb-1">Typ služby</label>
                <select id="service" name="service" class="w-full px-4 py-3 bg-white dark:bg-slate-700 border border-slate-200 dark:border-slate-600 rounded-lg focus:ring-2 focus:ring-orange-500 focus:border-orange-500 text-slate-800 dark:text-white">
                  <option value="">Vyberte službu...</option>
                  <option value="sadro">Sádrokarton</option>
                  <option value="obklady">Obklady a dlažba</option>
                  <option value="beton">Betonářské práce</option>
                  <option value="stavba">Stavební práce</option>
                  <option value="kuchyně">Kuchyň na míru</option>
                  <option value="jiné">Jiné</option>
                </select>
              </div>
              <div>
                <label for="message" class="block text-sm font-medium text-slate-700 dark:text-slate-300 mb-1">Zpráva *</label>
                <textarea id="message" name="message" rows="4" required class="w-full px-4 py-3 bg-white dark:bg-slate-700 border border-slate-200 dark:border-slate-600 rounded-lg focus:ring-2 focus:ring-orange-500 focus:border-orange-500 text-slate-800 dark:text-white resize-none" placeholder="Popište váš projekt..."></textarea>
              </div>
              <button type="submit" class="w-full py-4 bg-orange-500 hover:bg-orange-600 text-white font-semibold rounded-lg transition-colors flex items-center justify-center gap-2">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                </svg>
                <span>Odeslat zprávu</span>
              </button>
            </form>
          </div>
        </div>
      </div>
    </section>

    <!-- FAQ -->
    <section class="py-20 bg-slate-50 dark:bg-slate-800">
      <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-12">
          <span class="inline-block px-4 py-1 bg-orange-100 dark:bg-orange-900/30 text-orange-600 dark:text-orange-400 text-sm font-medium rounded-full mb-4">ČASTÉ DOTAZY</span>
          <h2 class="text-3xl font-bold text-slate-800 dark:text-white">Často kladené otázky</h2>
        </div>
        <div class="space-y-4" id="faq-container">
          <div class="bg-white dark:bg-slate-900 rounded-xl overflow-hidden">
            <button class="faq-toggle w-full px-6 py-4 text-left flex justify-between items-center" data-faq="1">
              <span class="font-medium text-slate-800 dark:text-white">Jak dlouho trvá rekonstrukce koupelny?</span>
              <svg class="w-5 h-5 text-slate-500 transform transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
              </svg>
            </button>
            <div class="faq-content px-6 pb-4 text-slate-600 dark:text-slate-400 hidden">
              <p>Standardní rekonstrukce koupelny trvá přibližně 2-3 týdny v závislosti na rozsahu prací. Menší opravy zvládneme i rychleji.</p>
            </div>
          </div>
          <div class="bg-white dark:bg-slate-900 rounded-xl overflow-hidden">
            <button class="faq-toggle w-full px-6 py-4 text-left flex justify-between items-center" data-faq="2">
              <span class="font-medium text-slate-800 dark:text-white">Poskytujete záruku na práce?</span>
              <svg class="w-5 h-5 text-slate-500 transform transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
              </svg>
            </button>
            <div class="faq-content px-6 pb-4 text-slate-600 dark:text-slate-400 hidden">
              <p>Ano, na veškeré naše práce poskytujeme záruku. Standardní záruční doba je 24 měsíců.</p>
            </div>
          </div>
          <div class="bg-white dark:bg-slate-900 rounded-xl overflow-hidden">
            <button class="faq-toggle w-full px-6 py-4 text-left flex justify-between items-center" data-faq="3">
              <span class="font-medium text-slate-800 dark:text-white">Provádíte práce i o víkendech?</span>
              <svg class="w-5 h-5 text-slate-500 transform transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
              </svg>
            </button>
            <div class="faq-content px-6 pb-4 text-slate-600 dark:text-slate-400 hidden">
              <p>Ano, v případě potřeby jsme schopni práce naplánovat i na víkendy, abychom neomezili provoz vašeho zařízení.</p>
            </div>
          </div>
          <div class="bg-white dark:bg-slate-900 rounded-xl overflow-hidden">
            <button class="faq-toggle w-full px-6 py-4 text-left flex justify-between items-center" data-faq="4">
              <span class="font-medium text-slate-800 dark:text-white">Jak probíhá cenová kalkulace?</span>
              <svg class="w-5 h-5 text-slate-500 transform transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
              </svg>
            </button>
            <div class="faq-content px-6 pb-4 text-slate-600 dark:text-slate-400 hidden">
              <p>Cenová nabídka je zdarma. Základě zaměření nebo zaslaných podkladů vám připravíme nezávaznou cenovou kalkulaci do 48 hodin.</p>
            </div>
          </div>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</BaseLayout>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement | null;
  form?.addEventListener('submit', (e) => {
    e.preventDefault();
    alert('Děkujeme za zprávu! Ozveme se vám co nejdříve.');
    form.reset();
  });

  // FAQ toggle
  document.querySelectorAll('.faq-toggle').forEach(btn => {
    btn.addEventListener('click', () => {
      const content = btn.nextElementSibling;
      const icon = btn.querySelector('svg');
      content?.classList.toggle('hidden');
      icon?.classList.toggle('rotate-180');
    });
  });
</script>
